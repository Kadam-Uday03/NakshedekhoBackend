<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Owner Dashboard - NaksheDekho Admin</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Outfit:wght@400;600;700;800&display=swap"
        rel="stylesheet">

    <link rel="stylesheet" href="../css/styles.css">
    <style>
        :root {
            --sidebar-width: 280px;
        }

        body {
            background: #f8fafc;
            overflow-x: hidden;
        }

        .owner-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* Sidebar Styling */
        .sidebar {
            width: var(--sidebar-width);
            background: var(--primary-blue);
            color: white;
            position: fixed;
            height: 100vh;
            padding: 2rem 1.5rem;
            display: flex;
            flex-direction: column;
            z-index: 100;
            box-shadow: 4px 0 20px rgba(0, 0, 0, 0.1);
        }

        .sidebar-brand {
            font-size: 1.5rem;
            font-weight: 800;
            color: white;
            text-decoration: none;
            margin-bottom: 3rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .sidebar-brand span {
            color: var(--accent-cyan);
        }

        .nav-list {
            list-style: none;
            flex: 1;
        }

        .nav-item {
            margin-bottom: 0.5rem;
        }

        .nav-btn {
            width: 100%;
            padding: 1rem 1.25rem;
            background: transparent;
            border: none;
            color: rgba(255, 255, 255, 0.7);
            font-family: inherit;
            font-size: 1rem;
            font-weight: 600;
            text-align: left;
            cursor: pointer;
            border-radius: 12px;
            transition: all 0.3s;
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .nav-btn i {
            font-size: 1.2rem;
            width: 24px;
        }

        .nav-btn:hover,
        .nav-btn.active {
            background: rgba(255, 255, 255, 0.1);
            color: white;
        }

        .nav-btn.active {
            background: var(--accent-cyan);
            color: white;
            box-shadow: 0 4px 15px rgba(0, 181, 226, 0.3);
        }

        .sidebar-footer {
            margin-top: auto;
            padding-top: 2rem;
            border-top: 1px solid rgba(255, 255, 255, 0.1);
        }

        /* Main Content Styling */
        .main-container {
            flex: 1;
            margin-left: var(--sidebar-width);
            padding: 2rem 3rem;
            transition: margin-left 0.3s;
        }

        .menu-toggle {
            display: none;
            position: fixed;
            top: 1rem;
            left: 1rem;
            z-index: 1001;
            background: var(--primary-blue);
            color: white;
            border: none;
            padding: 0.75rem;
            border-radius: 8px;
            cursor: pointer;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.2);
        }

        @media (max-width: 1024px) {
            .sidebar {
                transform: translateX(-100%);
                transition: transform 0.3s;
            }

            .sidebar.active {
                transform: translateX(0);
            }

            .main-container {
                margin-left: 0;
                padding: 5rem 1rem 2rem;
            }

            .menu-toggle {
                display: block;
            }

            .top-bar {
                flex-direction: column;
                align-items: flex-start;
                gap: 1.5rem;
            }

            .owner-table {
                display: block;
                overflow-x: auto;
            }
        }

        .top-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 3rem;
        }

        .page-title h1 {
            font-size: 2rem;
            color: var(--primary-blue);
            margin-bottom: 0.25rem;
        }

        .page-title p {
            color: var(--text-muted);
        }

        .admin-pill {
            background: white;
            padding: 0.5rem 1.5rem;
            border-radius: 50px;
            box-shadow: var(--premium-shadow);
            display: flex;
            align-items: center;
            gap: 1rem;
            border: 1px solid rgba(0, 0, 0, 0.05);
        }

        .admin-name {
            font-weight: 700;
            color: var(--primary-blue);
        }

        /* Dashboard Cards & Tables */
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 2rem;
            margin-bottom: 3rem;
        }

        .data-card {
            background: white;
            border-radius: 20px;
            padding: 2rem;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
            border: 1px solid rgba(0, 0, 0, 0.02);
            transition: transform 0.3s;
        }

        .data-card:hover {
            transform: translateY(-5px);
        }

        .label-tag {
            padding: 0.4rem 0.8rem;
            border-radius: 8px;
            font-size: 0.75rem;
            font-weight: 800;
            text-transform: uppercase;
        }

        .tag-blue {
            background: #E0F2FE;
            color: #0369A1;
        }

        .tag-green {
            background: #DCFCE7;
            color: #15803D;
        }

        .tag-orange {
            background: #FEF3C7;
            color: #92400e;
        }

        .owner-table {
            width: 100%;
            background: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
            border-collapse: collapse;
        }

        .owner-table th {
            background: #f8fafc;
            padding: 1.25rem 1.5rem;
            text-align: left;
            font-weight: 700;
            color: var(--text-muted);
            text-transform: uppercase;
            font-size: 0.75rem;
            letter-spacing: 0.05em;
        }

        .owner-table td {
            padding: 1.25rem 1.5rem;
            border-top: 1px solid #f1f5f9;
        }

        .owner-table tr:hover {
            background: #fafafa;
        }

        /* Tab Content */
        .tab-content {
            display: none;
            animation: fadeIn 0.4s ease-out;
        }

        .tab-content.active {
            display: block;
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(10px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Action Buttons */
        .icon-btn {
            width: 36px;
            height: 36px;
            border-radius: 10px;
            border: none;
            background: #f1f5f9;
            color: var(--primary-blue);
            cursor: pointer;
            transition: 0.2s;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-size: 1.1rem;
        }

        .icon-btn:hover {
            background: var(--primary-blue);
            color: white;
        }

        .icon-btn.delete:hover {
            background: #ef4444;
        }

        /* Modal Overlays from styles.css */

        .status-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            display: inline-block;
            margin-right: 6px;
        }
    </style>
</head>

<body>
    <button class="menu-toggle" id="menu-toggle">☰</button>
    <div class="owner-wrapper">
        <!-- Sidebar -->
        <aside class="sidebar">
            <a href="../index.html" class="sidebar-brand">
                <span>🏡</span> Nakshe<span>Dekho</span>
            </a>
            <ul class="nav-list">
                <li class="nav-item">
                    <button class="nav-btn active" onclick="switchTab('analytics', this)"><span>📊</span>
                        Dashboard</button>
                </li>
                <li class="nav-item">
                    <button class="nav-btn" onclick="switchTab('projects', this)"><span>📂</span> Projects</button>
                </li>
                <li class="nav-item">
                    <button class="nav-btn" onclick="switchTab('services', this)"><span>💎</span> Services</button>
                </li>
                <li class="nav-item">
                    <button class="nav-btn" onclick="switchTab('packages', this)"><span>📦</span> Packages</button>
                </li>
                <li class="nav-item">
                    <button class="nav-btn" onclick="switchTab('customers', this)"><span>👥</span> Customers</button>
                </li>
                <li class="nav-item">
                    <button class="nav-btn" onclick="switchTab('enquiries', this)"><span>📧</span> Enquiries</button>
                </li>
            </ul>
            <div class="sidebar-footer">
                <button class="nav-btn" onclick="logout()" style="color: #fda4af;"><span>🚪</span> Logout</button>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="main-container">
            <header class="top-bar">
                <div class="page-title">
                    <h1 id="view-title">Executive Overview</h1>
                    <p id="view-subtitle">Monitor growth and system operations.</p>
                </div>
                <div class="admin-pill">
                    <span class="admin-name" id="admin-name">Admin</span>
                    <div
                        style="width: 32px; height: 32px; background: var(--accent-cyan); border-radius: 50%; display: flex; align-items: center; justify-content: center; color: white; font-weight: 800; font-size: 0.8rem;">
                        AD</div>
                </div>
            </header>

            <!-- Dashboard / Analytics Tab -->
            <section id="analytics-tab" class="tab-content active">
                <div class="dashboard-grid" id="stats-summary">
                    <!-- Dynamic stats populated by JS -->
                    <div class="data-card">
                        <div class="spinner"></div>
                    </div>
                    <div class="data-card">
                        <div class="spinner"></div>
                    </div>
                    <div class="data-card">
                        <div class="spinner"></div>
                    </div>
                </div>

                <div class="data-card" style="padding-bottom: 1rem;">
                    <h3 class="mb-2">Recent System Events</h3>
                    <table class="owner-table" id="recent-table">
                        <thead>
                            <tr>
                                <th>Event Type</th>
                                <th>Subject</th>
                                <th>Status</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody id="recent-events-body">
                            <tr>
                                <td colspan="4" class="text-center">Synchronizing live data...</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </section>

            <!-- Projects Tab -->
            <section id="projects-tab" class="tab-content">
                <div class="data-card">
                    <div
                        style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem;">
                        <h3>Active Interior Projects</h3>
                        <div style="font-size: 0.9rem; color: var(--text-muted); font-weight: 600;">Manage all client
                            deliveries.</div>
                    </div>
                    <table class="owner-table">
                        <thead>
                            <tr>
                                <th>Project Name</th>
                                <th>Customer</th>
                                <th>Production Head</th>
                                <th>Stage</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="all-projects-body"></tbody>
                    </table>
                </div>
            </section>

            <!-- Services Tab (Regular One-Time Services) -->
            <section id="services-tab" class="tab-content">
                <div class="data-card">
                    <div
                        style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem;">
                        <div>
                            <h3>Service Inventory</h3>
                            <p style="color: var(--text-muted); font-size: 0.9rem; margin-top: 0.5rem;">
                                💎 Manage one-time design services that appear on the <a href="../services.html"
                                    target="_blank" style="color: var(--accent-cyan); font-weight: 600;">Services
                                    Page</a>
                            </p>
                        </div>
                        <button class="btn btn-primary btn-sm" onclick="openServiceModal()">+ New Service</button>
                    </div>
                    <table class="owner-table">
                        <thead>
                            <tr>
                                <th>Service Name</th>
                                <th>Area (sqft)</th>
                                <th>Base Price</th>
                                <th>Offer</th>
                                <th>Status</th>
                                <th>Action</th>
                            </tr>
                        </thead>
                        <tbody id="all-services-body"></tbody>
                    </table>
                </div>
            </section>

            <!-- Customers Tab -->
            <section id="customers-tab" class="tab-content">
                <div class="data-card">
                    <h3 class="mb-2">Customer Universe</h3>
                    <table class="owner-table">
                        <thead>
                            <tr>
                                <th>Full Identity</th>
                                <th>Communication</th>
                                <th>Registration</th>
                                <th>Account</th>
                            </tr>
                        </thead>
                        <tbody id="all-customers-body"></tbody>
                    </table>
                </div>
            </section>

            <!-- Enquiries Tab -->
            <section id="enquiries-tab" class="tab-content">
                <div class="data-card">
                    <h3 class="mb-2">General Enquiries</h3>
                    <table class="owner-table">
                        <thead>
                            <tr>
                                <th>Sender</th>
                                <th>Message Brief</th>
                                <th>Incoming On</th>
                                <th>Follow-up</th>
                            </tr>
                        </thead>
                        <tbody id="all-enquiries-body"></tbody>
                    </table>
                </div>
            </section>
        </main>
    </div>

    <!-- Modals (Functional Backends) -->
    <div id="pkg-modal" class="modal-overlay">
        <div class="modal-content">
            <span class="modal-close" onclick="closeModal('pkg-modal')">&times;</span>
            <h2 id="modal-title">Service Configuration</h2>
            <form id="pkg-form" onsubmit="handlePackageSave(event)">
                <input type="hidden" id="edit-id">
                <div class="form-group">
                    <label class="form-label">Service Name</label>
                    <input type="text" id="p-name" class="form-input" required
                        placeholder="Ex: Premium 2BHK Interior Design">
                </div>
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                    <div class="form-group">
                        <label class="form-label">Sqft Coverage</label>
                        <input type="number" id="p-area" class="form-input" required placeholder="0">
                    </div>
                    <div class="form-group">
                        <label class="form-label">Price (INR)</label>
                        <input type="number" id="p-price" class="form-input" required placeholder="0">
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Inclusions Scope</label>
                    <textarea id="p-desc" class="form-textarea" required
                        placeholder="List what's included..."></textarea>
                </div>
                <div class="form-group">
                    <label class="form-label">Service Image URL (Optional)</label>
                    <input type="url" id="p-image" class="form-input" placeholder="https://example.com/image.jpg">
                    <small style="color: var(--text-muted); font-size: 0.85rem; display: block; margin-top: 0.5rem;">
                        💡 Provide a URL to an image that represents this service. Leave blank for default image.
                    </small>
                </div>

                <!-- Offer/Discount Section -->
                <div style="border-top: 2px solid #f1f5f9; padding-top: 1.5rem; margin-top: 1rem;">
                    <h3 style="font-size: 1.1rem; color: var(--primary-blue); margin-bottom: 1rem;">🎁 Special Offer
                        (Optional)</h3>
                    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                        <div class="form-group">
                            <label class="form-label">Discount %</label>
                            <input type="number" id="p-discount" class="form-input" min="0" max="100"
                                placeholder="e.g., 20">
                        </div>
                        <div class="form-group">
                            <label class="form-label">Valid Until</label>
                            <input type="date" id="p-offer-valid" class="form-input">
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Offer Description</label>
                        <input type="text" id="p-offer-desc" class="form-input"
                            placeholder="e.g., New Year Special Discount">
                    </div>
                </div>

                <!-- Subscription Configuration Section -->
                <div style="border-top: 2px solid #f1f5f9; padding-top: 1.5rem; margin-top: 1rem;">
                    <h3 style="font-size: 1.1rem; color: var(--primary-blue); margin-bottom: 1rem;">📦 Subscription
                        Settings</h3>

                    <div class="form-group">
                        <label class="form-label" style="display: flex; align-items: center; gap: 0.5rem;">
                            <input type="checkbox" id="p-is-subscription" style="width: auto;">
                            <span>This is a Subscription Package</span>
                        </label>
                        <small
                            style="color: var(--text-muted); font-size: 0.85rem; display: block; margin-top: 0.5rem;">
                            💡 Enable for recurring subscription plans shown on Packages page
                        </small>
                    </div>

                    <div id="subscription-fields" style="display: none;">
                        <div class="form-group">
                            <label class="form-label">Package Tier</label>
                            <select id="p-tier" class="form-select">
                                <option value="">Select Tier</option>
                                <option value="BASIC">Basic (20% OFF)</option>
                                <option value="STANDARD">Standard (40% OFF)</option>
                                <option value="PREMIUM">Premium (60% OFF) - Featured</option>
                                <option value="ENTERPRISE">Enterprise (Custom)</option>
                            </select>
                        </div>

                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                            <div class="form-group">
                                <label class="form-label">Max Projects/Year</label>
                                <input type="number" id="p-max-projects" class="form-input" min="0"
                                    placeholder="Leave blank for unlimited">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Revisions/Project</label>
                                <input type="number" id="p-max-revisions" class="form-input" min="0"
                                    placeholder="e.g., 3">
                            </div>
                        </div>

                        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
                            <div class="form-group">
                                <label class="form-label">Site Visits/Project</label>
                                <input type="number" id="p-site-visits" class="form-input" min="0" value="0"
                                    placeholder="e.g., 2">
                            </div>
                            <div class="form-group">
                                <label class="form-label">Duration (Days)</label>
                                <input type="number" id="p-duration" class="form-input" min="1" value="365"
                                    placeholder="365">
                            </div>
                        </div>

                        <div class="form-group">
                            <label class="form-label" style="display: flex; align-items: center; gap: 0.5rem;">
                                <input type="checkbox" id="p-3d-viz" style="width: auto;">
                                <span>Include 3D Visualization</span>
                            </label>
                        </div>

                        <div class="form-group">
                            <label class="form-label" style="display: flex; align-items: center; gap: 0.5rem;">
                                <input type="checkbox" id="p-priority-support" style="width: auto;">
                                <span>Priority Support</span>
                            </label>
                        </div>
                    </div>
                </div>

                <button type="submit" class="btn btn-primary w-100">Commit Changes</button>
            </form>
        </div>
    </div>

    <div id="assign-modal" class="modal-overlay">
        <div class="modal-content">
            <span class="modal-close" onclick="closeModal('assign-modal')">&times;</span>
            <h2>Dispatch Project to Manager</h2>
            <p class="mb-2">Select an available production head for this project.</p>
            <form onsubmit="handleAssignment(event)">
                <input type="hidden" id="assign-pid">
                <div class="form-group">
                    <label class="form-label">Select Resource</label>
                    <select id="manager-select" class="form-select" required></select>
                </div>
                <button type="submit" class="btn btn-primary w-100">Confirm Assignment</button>
            </form>
        </div>
    </div>

    <script src="../js/api.js"></script>
    <script src="../js/auth.js"></script>
    <script>
        // Check Access
        if (!requireRole('OWNER_ADMIN')) { location.href = '/login.html'; }

        const user = getCurrentUser();
        if (user) document.getElementById('admin-name').textContent = user.fullName;

        // Navigation Logic
        function switchTab(tabId, el) {
            document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
            document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));

            document.getElementById(tabId + '-tab').classList.add('active');
            el.classList.add('active');

            const viewTitles = {
                analytics: ['Executive Overview', 'Monitor growth and system operations.'],
                projects: ['Project Dashboard', 'Oversee all active design deliveries.'],
                packages: ['Service Catalog', 'Configure design plans and pricing.'],
                customers: ['Client Directory', 'Manage user accounts and relationships.'],
                enquiries: ['Marketing Leads', 'Track and respond to new enquiries.']
            };

            document.getElementById('view-title').textContent = viewTitles[tabId][0];
            document.getElementById('view-subtitle').textContent = viewTitles[tabId][1];

            if (tabId === 'analytics') loadDashboardData();
            if (tabId === 'projects') loadProjects();
            if (tabId === 'packages') loadPackages();
            if (tabId === 'customers') loadCustomers();
            if (tabId === 'enquiries') loadEnquiries();
        }

        async function loadDashboardData() {
            try {
                const stats = await ownerAPI.getAnalytics();
                const container = document.getElementById('stats-summary');
                container.innerHTML = `
                    <div class="data-card">
                        <p class="label-tag tag-blue mb-1">Total Scale</p>
                        <h1 style="font-size: 2.5rem; color: var(--primary-blue);">${stats.totalProjects}</h1>
                        <small>Registered Projects</small>
                    </div>
                    <div class="data-card">
                        <p class="label-tag tag-green mb-1">Production</p>
                        <h1 style="font-size: 2.5rem; color: var(--primary-blue);">${stats.activeProjects}</h1>
                        <small>Live Projects in Stream</small>
                    </div>
                    <div class="data-card">
                        <p class="label-tag tag-orange mb-1">Customers</p>
                        <h1 style="font-size: 2.5rem; color: var(--primary-blue);">${stats.totalCustomers}</h1>
                        <small>Verified Client Base</small>
                    </div>
                `;

                // Load some recent projects as "events"
                const projects = await ownerAPI.getAllProjects();
                const recentBody = document.getElementById('recent-events-body');
                recentBody.innerHTML = projects.slice(0, 5).map(p => `
                    <tr>
                        <td><strong>New Order</strong></td>
                        <td>${p.projectName}</td>
                        <td><span class="label-tag tag-blue">${p.status}</span></td>
                        <td>${new Date(p.createdAt).toLocaleDateString()}</td>
                    </tr>
                `).join('');
            } catch (e) { console.error(e); }
        }

        async function loadProjects() {
            const body = document.getElementById('all-projects-body');
            try {
                const projects = await ownerAPI.getAllProjects();
                body.innerHTML = projects.map(p => `
                    <tr>
                        <td style="font-weight: 700;">${p.projectName}</td>
                        <td>${p.customer?.fullName || 'N/A'}</td>
                        <td>
                            <button onclick="openAssign(${p.id}, ${p.manager?.id || null})" class="nav-btn" style="padding: 0.4rem 0.8rem; border: 1px dashed var(--accent-cyan); color: var(--accent-cyan); font-size: 0.8rem; width: fit-content;">
                                ${p.manager ? '👤 ' + p.manager.fullName : '➕ Assign Head'}
                            </button>
                        </td>
                        <td>
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <div style="flex: 1; height: 6px; background: #eee; border-radius: 3px; min-width: 80px;">
                                    <div style="width: ${p.progressPercentage}%; height: 100%; background: var(--accent-cyan); border-radius: 3px;"></div>
                                </div>
                                <span style="font-size: 0.8rem; font-weight: 700;">${p.progressPercentage}%</span>
                            </div>
                        </td>
                        <td>
                            <button onclick="handleDelete('project', ${p.id})" class="icon-btn delete">🗑️</button>
                        </td>
                    </tr>
                `).join('');
            } catch (e) { }
        }

        async function loadPackages() {
            const body = document.getElementById('all-packages-body');
            try {
                const pkgs = await ownerAPI.getAllPackages();
                body.innerHTML = pkgs.map(p => {
                    const hasOffer = p.discountPercentage && p.discountPercentage > 0;
                    const isOfferValid = hasOffer && (!p.offerValidUntil || new Date(p.offerValidUntil) > new Date());
                    return `
                    <tr>
                        <td style="font-weight: 700; color: var(--primary-blue);">${p.name}</td>
                        <td>${p.areaSqft} sqft</td>
                        <td style="color: #15803D; font-weight: 800;">${formatCurrency(p.price)}</td>
                        <td>
                            ${isOfferValid ? `
                                <span class="label-tag" style="background: #FEF3C7; color: #92400e; font-size: 0.7rem;">
                                    🎁 ${p.discountPercentage}% OFF
                                </span>
                            ` : '<span style="color: var(--text-muted); font-size: 0.8rem;">No offer</span>'}
                        </td>
                        <td><span class="status-dot" style="background: ${p.active ? '#22c55e' : '#cbd5e1'}"></span> ${p.active ? 'Active' : 'Archived'}</td>
                        <td>
                            <button onclick='openPkgEdit(${JSON.stringify(p)})' class="icon-btn">✏️</button>
                            <button onclick="handleDelete('package', ${p.id})" class="icon-btn delete">🗑️</button>
                        </td>
                    </tr>
                `}).join('');
            } catch (e) { }
        }

        async function loadCustomers() {
            const body = document.getElementById('all-customers-body');
            try {
                const data = await ownerAPI.getAllCustomers();
                body.innerHTML = data.map(c => `
                    <tr>
                        <td>
                            <div style="font-weight: 700;">${c.fullName}</div>
                            <small style="color: var(--text-muted);">Ref: #${c.id}</small>
                        </td>
                        <td>${c.email}<br><small>${c.phone || 'No phone'}</small></td>
                        <td>${new Date(c.createdAt).toLocaleDateString()}</td>
                        <td><button onclick="handleDelete('customer', ${c.id})" class="nav-btn" style="color: #ef4444; width: fit-content; padding: 0.25rem 0.75rem;">Disable</button></td>
                    </tr>
                `).join('');
            } catch (e) { }
        }

        async function loadEnquiries() {
            const body = document.getElementById('all-enquiries-body');
            try {
                const data = await ownerAPI.getAllEnquiries();
                body.innerHTML = data.map(e => `
                    <tr>
                        <td>
                            <strong>${e.name}</strong><br>
                            <small>${e.email}</small><br>
                            <small style="color:var(--accent-cyan); font-weight:700;">${e.phone || 'No Phone'}</small>
                        </td>
                        <td><div style="max-width: 250px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">${e.message}</div></td>
                        <td>${new Date(e.submittedAt).toLocaleDateString()}</td>
                        <td>
                            ${e.contacted ? '<span class="label-tag tag-green">Done</span>' : `<button onclick="markDone(${e.id})" class="btn-sm btn-outline">Close</button>`}
                        </td>
                    </tr>
                `).join('');
            } catch (e) { }
        }

        // Action Modals & Handlers
        function closeModal(id) { document.getElementById(id).style.display = 'none'; }

        function openPackageModal() {
            document.getElementById('pkg-form').reset();
            document.getElementById('edit-id').value = '';
            document.getElementById('modal-title').textContent = 'Configure New Service';
            document.getElementById('pkg-modal').style.display = 'flex';
        }

        function openPkgEdit(p) {
            document.getElementById('edit-id').value = p.id;
            document.getElementById('p-name').value = p.name;
            document.getElementById('p-area').value = p.areaSqft;
            document.getElementById('p-price').value = p.price;
            document.getElementById('p-desc').value = p.description;
            document.getElementById('p-image').value = p.imageUrl || '';
            document.getElementById('p-discount').value = p.discountPercentage || '';
            document.getElementById('p-offer-desc').value = p.offerDescription || '';
            if (p.offerValidUntil) {
                const date = new Date(p.offerValidUntil);
                document.getElementById('p-offer-valid').value = date.toISOString().split('T')[0];
            } else {
                document.getElementById('p-offer-valid').value = '';
            }

            // Subscription fields
            document.getElementById('p-is-subscription').checked = p.isSubscription || false;
            document.getElementById('p-tier').value = p.packageTier || '';
            document.getElementById('p-max-projects').value = p.maxProjects || '';
            document.getElementById('p-max-revisions').value = p.maxRevisions || '';
            document.getElementById('p-site-visits').value = p.includesSiteVisits || 0;
            document.getElementById('p-duration').value = p.subscriptionDurationDays || 365;
            document.getElementById('p-3d-viz').checked = p.includes3dVisualization || false;
            document.getElementById('p-priority-support').checked = p.prioritySupport || false;

            // Toggle subscription fields visibility
            document.getElementById('subscription-fields').style.display = p.isSubscription ? 'block' : 'none';

            document.getElementById('modal-title').textContent = 'Edit Service Config';
            document.getElementById('pkg-modal').style.display = 'flex';
        }

        async function handlePackageSave(e) {
            e.preventDefault();
            const id = document.getElementById('edit-id').value;
            const data = {
                name: document.getElementById('p-name').value,
                areaSqft: parseInt(document.getElementById('p-area').value),
                price: parseFloat(document.getElementById('p-price').value),
                description: document.getElementById('p-desc').value
            };

            // Add image URL if provided
            const imageUrl = document.getElementById('p-image').value;
            if (imageUrl) {
                data.imageUrl = imageUrl;
            }

            // Add offer fields if provided
            const discount = document.getElementById('p-discount').value;
            const offerDesc = document.getElementById('p-offer-desc').value;
            const offerValid = document.getElementById('p-offer-valid').value;

            if (discount && parseInt(discount) > 0) {
                data.discountPercentage = parseInt(discount);
            }
            if (offerDesc) {
                data.offerDescription = offerDesc;
            }
            if (offerValid) {
                data.offerValidUntil = new Date(offerValid).toISOString();
            }

            // Add subscription fields
            data.isSubscription = document.getElementById('p-is-subscription').checked;
            if (data.isSubscription) {
                data.packageTier = document.getElementById('p-tier').value;
                const maxProjects = document.getElementById('p-max-projects').value;
                if (maxProjects) data.maxProjects = parseInt(maxProjects);
                const maxRevisions = document.getElementById('p-max-revisions').value;
                if (maxRevisions) data.maxRevisions = parseInt(maxRevisions);
                data.includesSiteVisits = parseInt(document.getElementById('p-site-visits').value) || 0;
                data.subscriptionDurationDays = parseInt(document.getElementById('p-duration').value) || 365;
                data.includes3dVisualization = document.getElementById('p-3d-viz').checked;
                data.prioritySupport = document.getElementById('p-priority-support').checked;
            }

            try {
                if (id) await ownerAPI.updatePackage(id, data);
                else await ownerAPI.createPackage(data);
                showNotification('Inventory updated successfully.');
                closeModal('pkg-modal');
                loadPackages();
            } catch (err) { showNotification('Save failed', 'error'); }
        }

        async function openAssign(pid, mid) {
            document.getElementById('assign-pid').value = pid;
            const sel = document.getElementById('manager-select');
            sel.innerHTML = '<option>Searching resources...</option>';
            document.getElementById('assign-modal').style.display = 'flex';
            try {
                const managers = await ownerAPI.getAllManagers();
                sel.innerHTML = managers.map(m => `<option value="${m.id}" ${m.id === mid ? 'selected' : ''}>${m.fullName}</option>`).join('');
            } catch (e) { sel.innerHTML = '<option>Error loading resources</option>'; }
        }

        async function handleAssignment(e) {
            e.preventDefault();
            const pid = document.getElementById('assign-pid').value;
            const mid = document.getElementById('manager-select').value;
            try {
                await ownerAPI.assignManager(pid, mid);
                showNotification('Project dispatched successfully.');
                closeModal('assign-modal');
                loadProjects();
            } catch (e) { showNotification('Dispatch failed', 'error'); }
        }

        async function handleDelete(type, id) {
            if (!confirm(`Are you sure you want to remove this ${type}?`)) return;
            try {
                if (type === 'project') await ownerAPI.deleteProject(id);
                if (type === 'package') await ownerAPI.deletePackage(id);
                if (type === 'customer') await ownerAPI.deleteCustomer(id);
                showNotification('Entity removed.');
                if (type === 'project') loadProjects();
                if (type === 'package') loadPackages();
                if (type === 'customer') loadCustomers();
            } catch (e) { showNotification('Action failed', 'error'); }
        }

        async function markDone(id) {
            try { await ownerAPI.markEnquiryContacted(id); loadEnquiries(); } catch (e) { }
        }

        function logout() { authAPI.logout(); }

        // Initial Load
        // Sidebar Toggle for Mobile
        const menuToggle = document.getElementById('menu-toggle');
        const sidebar = document.querySelector('.sidebar');
        if (menuToggle) {
            menuToggle.addEventListener('click', () => {
                sidebar.classList.toggle('active');
                menuToggle.textContent = sidebar.classList.contains('active') ? '✕' : '☰';
            });
        }

        // Close sidebar when clicking links on mobile
        document.querySelectorAll('.nav-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                if (window.innerWidth <= 1024) {
                    sidebar.classList.remove('active');
                    menuToggle.textContent = '☰';
                }
            });
        });

        // Subscription toggle handler
        document.getElementById('p-is-subscription').addEventListener('change', function () {
            document.getElementById('subscription-fields').style.display = this.checked ? 'block' : 'none';
        });

        document.addEventListener('DOMContentLoaded', loadDashboardData);
    </script>
</body>

</html>