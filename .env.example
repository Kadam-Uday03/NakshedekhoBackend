# =============================================================================
# NaksheDekho — Environment Variables Template
# =============================================================================
# INSTRUCTIONS:
#   1. Copy this file:  cp .env.example .env
#   2. Fill in ALL values below with your real credentials
#   3. NEVER commit the .env file to git (already in .gitignore)
#   4. Use strong, unique passwords for each variable
#   5. Generate a JWT secret: openssl rand -base64 64
# =============================================================================

# ── PostgreSQL Database ────────────────────────────────────────────────────────
# For local development: DB_HOST=localhost
# For Docker/production: DB_HOST=your-db-host or container name
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nakshedekho_db
DB_USERNAME=nakshedekho_user
DB_PASSWORD=CHANGE_ME_strong_db_password_here

# ── JWT Secret ─────────────────────────────────────────────────────────────────
# MUST be at least 64 characters for HS256 security.
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_minimum_64_character_jwt_secret_key_replace_this_now_!!

# ── Razorpay ───────────────────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=XXXXXXXXXXXXXXXXXXXXXXXX

# ── Gmail SMTP ─────────────────────────────────────────────────────────────────
# Use an App Password (NOT your Gmail login password)
# Generate at: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ── Admin Seed Accounts ────────────────────────────────────────────────────────
# These admin accounts are created automatically on first server boot.
# Use strong passwords with uppercase, lowercase, numbers, and symbols.
ADMIN_OWNER_EMAIL=owner@yourdomain.com
ADMIN_OWNER_PASSWORD=CHANGE_ME_strong_owner_password1!
ADMIN_OWNER2_EMAIL=owner2@yourdomain.com
ADMIN_OWNER2_PASSWORD=CHANGE_ME_strong_owner_password2!
ADMIN_MANAGER_EMAIL=manager@yourdomain.com
ADMIN_MANAGER_PASSWORD=CHANGE_ME_strong_manager_password1!

# ── Google OAuth (Optional) ────────────────────────────────────────────────────
# Leave empty to disable Google Sign-in.
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
